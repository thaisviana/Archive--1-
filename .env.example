# Database Configuration
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/agent_memory

# OpenAI API Key (required for LLM features)
OPENAI_API_KEY=sk-proj-your-api-key-here

# Optional: Langfuse Observability
# LANGFUSE_PUBLIC_KEY=your-public-key
# LANGFUSE_SECRET_KEY=your-secret-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: Graphiti Knowledge Graph
# GRAPHITI_API_URL=http://localhost:8000
# GRAPHITI_API_KEY=your-api-key

# Python Environment (auto-detected, usually not needed)
# PYTHONPATH=.
